    {
      "parameters": {
        "jsCode": "// Aggregate data from all parent tables for monthly and master summaries\nconst items = $input.all();\nconst config = $('Workflow Configuration').item.json;\n\n// Initialize aggregation objects\nconst monthlySummary = {};\nconst masterSummary = {};\n\n// Process each item from the archived data\nfor (const item of items) {\n  const data = item.json;\n  const parentTable = data.parentTable || 'Unknown';\n  \n  // Aggregate for monthly summary (current month's data)\n  if (!monthlySummary[parentTable]) {\n    monthlySummary[parentTable] = {\n      parentTable: parentTable,\n      totalRecords: 0,\n      // Add other fields you want to aggregate\n    };\n  }\n  monthlySummary[parentTable].totalRecords++;\n  \n  // Aggregate for master summary (all-time data)\n  if (!masterSummary[parentTable]) {\n    masterSummary[parentTable] = {\n      parentTable: parentTable,\n      totalRecords: 0,\n      // Add other fields you want to aggregate\n    };\n  }\n  masterSummary[parentTable].totalRecords++;\n}\n\n// Convert aggregation objects to arrays\nconst monthlyResults = Object.values(monthlySummary);\nconst masterResults = Object.values(masterSummary);\n\n// Return both summaries\nreturn [\n  {\n    json: {\n      monthlySummary: monthlyResults,\n      masterSummary: masterResults,\n      baseId: config.baseId,\n      monthlySummaryTableId: config.monthlySummaryTableId,\n      masterSummaryTableId: config.masterSummaryTableId,\n      timestamp: new Date().toISOString()\n    }\n  }\n];"
      },
      "id": "73696bd7-f3cf-46f7-83cc-2e7f32869260",
      "name": "Aggregate All Data for Summaries",
