      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Process each parent table and create table IDs for Week 1-4\nconst parentTable = $input.item.json.parentTable;\nconst baseId = $input.item.json.baseId;\n\n// Create table IDs based on parent table name\nconst week1TableId = `${parentTable}_Week1`;\nconst week2TableId = `${parentTable}_Week2`;\nconst week3TableId = `${parentTable}_Week3`;\nconst week4TableId = `${parentTable}_Week4`;\n\nreturn {\n  parentTable: parentTable,\n  baseId: baseId,\n  week1TableId: week1TableId,\n  week2TableId: week2TableId,\n  week3TableId: week3TableId,\n  week4TableId: week4TableId,\n  archiveTableId: $input.item.json.archiveTableId,\n  monthlySummaryTableId: $input.item.json.monthlySummaryTableId,\n  masterSummaryTableId: $input.item.json.masterSummaryTableId\n};"
      },
