      "parameters": {
        "jsCode": "// Get the parent tables array from the configuration\nconst parentTables = $input.first().json.parentTables;\n\n// Create an array of items, one for each parent table\nconst items = parentTables.map(tableName => ({\n  json: {\n    parentTable: tableName,\n    baseId: $input.first().json.baseId,\n    archiveTableId: $input.first().json.archiveTableId,\n    monthlySummaryTableId: $input.first().json.monthlySummaryTableId,\n    masterSummaryTableId: $input.first().json.masterSummaryTableId\n  }\n}));\n\nreturn items;"
      },
      "id": "d06d52fd-c08f-46f2-b06e-fe1c91147e43",
      "name": "Create Parent Table List",
      "type": "n8n-nodes-base.code",
